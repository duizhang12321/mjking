.title { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
.actions button { margin-right: 12px; }
.list { margin-top: 12px; }
.item { background:#fff; border:1px solid #e5e6eb; border-radius:8px; padding:12px; margin-bottom:10px; }
.name { font-size:16px; }
.badge { font-size:12px; color:#07c160; border:1px solid #07c160; border-radius:6px; padding:0 6px; margin-left:6px; }
.sub { color:#86909c; font-size:12px; margin-top:4px; }
.ops { margin-top:8px; display:flex; gap:8px; }
.empty { color:#86909c; margin-top:12px; }
