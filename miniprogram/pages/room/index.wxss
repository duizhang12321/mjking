.title { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
.block { background:#fff; border:1px solid #e5e6eb; border-radius:8px; padding:12px; margin-bottom:10px; }
.label { color:#86909c; margin-bottom:6px; }
.players { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
.player { background:#f2f3f5; padding:6px 8px; border-radius:6px; }
.actions button { margin-right: 12px; }
.list .subtitle { margin:12px 0; font-weight:600; }
.item { background:#fff; border:1px solid #e5e6eb; border-radius:8px; padding:12px; margin-bottom:10px; }
.sub { color:#86909c; font-size:12px; margin-top:4px; }
.empty { color:#86909c; margin-top:12px; }
