.title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 12px;
}

.preview {
  height: 200px;
  background: #fff;
  border: 1px solid #e5e6eb;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.image {
  max-width: 100%;
  max-height: 100%;
}

.placeholder {
  color: #86909c;
}

.actions button {
  margin-right: 12px;
}

.result {
  margin-top: 12px;
  font-size: 16px;
  color: #07c160;
}

.error {
  margin-top: 12px;
  font-size: 14px;
  color: #fa5151;
}
