<view class="container">
  <view class="title">AI 图片评分</view>

  <view class="preview">
    <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="aspectFit" class="image"></image>
    <view wx:else class="placeholder">未选择图片</view>
  </view>

  <view class="actions">
    <button type="primary" bindtap="chooseImage">选择图片</button>
    <button type="warn" bindtap="reset" disabled="{{!imagePath}}">重置</button>
    <button class="submit" bindtap="submit" disabled="{{!imagePath || uploading}}">{{uploading ? '评分中...' : '计算分数'}}</button>
  </view>

  <view wx:if="{{score !== null}}" class="result">评分：{{score}}</view>
  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
